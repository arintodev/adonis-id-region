{
  "name": "@arintodev/adonis-indonesia-region",
  "version": "1.0.0",
  "description": "Reusable region module for AdonisJS 7",
  "type": "module",
  "main": "build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./services": "./build/src/services/region_service.js",
